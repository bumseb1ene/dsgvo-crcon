################################################################################
# CRCON DSGVO baseline example
#
# Copy to .env and fill the empty values before starting the stack.
# Do not put inline comments after values; Docker env files treat # characters
# inside values differently than many people expect.
################################################################################

REDIS_IMAGE=redis:alpine
POSTGRES_IMAGE=postgres:12-alpine
BACKEND_DOCKER_REPOSITORY=cericmathey/hll_rcon_tool
FRONTEND_DOCKER_REPOSITORY=cericmathey/hll_rcon_tool_frontend
TAGGED_VERSION=latest

HLL_DB_PASSWORD=
HLL_DB_NAME=rcon
HLL_DB_USER=rcon
HLL_DB_HOST=postgres
HLL_DB_HOST_PORT=5432
HLL_REDIS_HOST=redis
HLL_REDIS_HOST_PORT=6379
RCONWEB_API_SECRET=

NB_API_WORKERS=1
NB_API_THREADS=8

# Keep login cookies scoped to the exact host unless you fully control every
# subdomain and have documented the takeover/session-theft risk.
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
DJANGO_DEBUG=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=false
SECURE_PROXY_SSL_HEADER=false

# Remote error monitoring is disabled by default. If you enable Sentry, use a
# signed data processing agreement and keep default PII disabled.
SENTRY_DSN=
SENTRY_SEND_DEFAULT_PII=false

# Do not create the predictable admin/admin account. Create named admin users
# manually and assign only the permissions they need.
DONT_SEED_ADMIN_USER=1
LOGGING_LEVEL=INFO
SENTRY_BREADCRUMB_LEVEL=INFO

RCONWEB_EXTERNAL_ADDRESS=localhost

################################################################################
# Server 1
################################################################################

HLL_HOST=
HLL_PORT=
HLL_PASSWORD=

# Bind public services to localhost until a TLS reverse proxy is configured.
RCONWEB_PORT=127.0.0.1:8010
RCONWEB_PORT_HTTPS=127.0.0.1:9010
PUBLIC_STATS_PORT=127.0.0.1:7010
PUBLIC_STATS_PORT_HTTPS=127.0.0.1:7011

GTX_SERVER_NAME_CHANGE_USERNAME=
GTX_SERVER_NAME_CHANGE_PASSWORD=
SERVER_NUMBER=1
HLL_REDIS_DB=1
